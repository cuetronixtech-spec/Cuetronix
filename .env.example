# ─────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────
# Platform Payment (YOUR Stripe account — for SaaS subscriptions)
# ─────────────────────────────────────────────────────────
PLATFORM_STRIPE_SECRET_KEY=sk_live_xxx
PLATFORM_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
PLATFORM_STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─────────────────────────────────────────────────────────
# Tenant Secret Encryption
# AES-256-GCM key — must be exactly 64 hex chars (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────
TENANT_SECRET_ENCRYPTION_KEY=64_char_hex_string_replace_this

# ─────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM_ADDRESS=noreply@cuetronix.com
EMAIL_FROM_NAME=Cuetronix

# ─────────────────────────────────────────────────────────
# AI
# ─────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ─────────────────────────────────────────────────────────
# Upstash Redis
# ─────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─────────────────────────────────────────────────────────
# Vercel (for custom domain provisioning API)
# ─────────────────────────────────────────────────────────
VERCEL_TOKEN=xxx
VERCEL_PROJECT_ID=xxx
VERCEL_TEAM_ID=xxx

# ─────────────────────────────────────────────────────────
# Monitoring
# ─────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ─────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────
VITE_APP_DOMAIN=cuetronix.com
VITE_APP_BASE_URL=https://app.cuetronix.com
NODE_ENV=production

# ─────────────────────────────────────────────────────────
# Sandbox (fixed UUIDs — seeded once at platform setup)
# ─────────────────────────────────────────────────────────
SANDBOX_TENANT_ID=00000000-0000-0000-0000-000000000001
SANDBOX_ADMIN_USER_ID=00000000-0000-0000-0000-000000000002
SANDBOX_STAFF_USER_ID=00000000-0000-0000-0000-000000000003
SANDBOX_MANAGER_USER_ID=00000000-0000-0000-0000-000000000004
